<Window x:Class="RenderFarm.Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RenderFarm Launcher"
        Width="980"
        Height="720"
        MinWidth="860"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F8">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#172033" />
            <Setter Property="FontSize" Value="14" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Margin" Value="0,4,0,12" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,0,16" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="Foreground" Value="#172033" />
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#D8DEE8" BorderThickness="1" CornerRadius="8" Padding="18" Margin="0,0,0,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="RenderFarm Launcher" FontSize="26" FontWeight="SemiBold" />
                    <TextBlock Text="Choose what this machine does, save the role, and start the C# runtime without opening a terminal." Foreground="#526078" Margin="0,6,0,0" />
                </StackPanel>
                <Border Grid.Column="1" Background="#E8F2FF" BorderBrush="#BBD7FF" BorderThickness="1" CornerRadius="12" Padding="12,7" VerticalAlignment="Center">
                    <TextBlock Text="C# runtime" Foreground="#14559B" FontWeight="SemiBold" />
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="310" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#D8DEE8" BorderThickness="1" CornerRadius="8" Padding="18">
                <StackPanel>
                    <TextBlock Text="Machine role" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Text="The controller owns the dashboard, queue, scheduler, and SQLite database. Workers connect to the controller and launch Unreal jobs." Foreground="#526078" TextWrapping="Wrap" Margin="0,8,0,18" />

                    <RadioButton x:Name="ControllerRole" Content="Controller" FontWeight="SemiBold" Margin="0,0,0,8" Checked="RoleChanged" />
                    <TextBlock Text="Use this on the main PC that operators browse to." Foreground="#526078" Margin="24,0,0,18" TextWrapping="Wrap" />

                    <RadioButton x:Name="WorkerRole" Content="Worker" FontWeight="SemiBold" Margin="0,0,0,8" Checked="RoleChanged" />
                    <TextBlock Text="Use this on render machines with Unreal installed and access to project/output paths." Foreground="#526078" Margin="24,0,0,22" TextWrapping="Wrap" />

                    <Separator Margin="0,0,0,16" />
                    <TextBlock Text="Saved settings" FontWeight="SemiBold" />
                    <TextBlock x:Name="SettingsPathText" Foreground="#526078" TextWrapping="Wrap" Margin="0,6,0,0" />
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <GroupBox x:Name="ControllerPanel" Header="Controller settings">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="150" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Host name or IP" FontWeight="SemiBold" />
                                <TextBox x:Name="HostNameBox" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Port" FontWeight="SemiBold" />
                                <TextBox x:Name="PortBox" />
                            </StackPanel>
                        </Grid>
                    </GroupBox>

                    <GroupBox x:Name="WorkerPanel" Header="Worker settings">
                        <StackPanel>
                            <TextBlock Text="Controller URL" FontWeight="SemiBold" />
                            <TextBox x:Name="ControllerUrlBox" />

                            <CheckBox x:Name="DiscoveryEnabledBox" Content="Allow LAN discovery when Controller URL is blank" Margin="0,0,0,14" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Worker ID" FontWeight="SemiBold" />
                                    <TextBox x:Name="WorkerIdBox" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Display name" FontWeight="SemiBold" />
                                    <TextBox x:Name="DisplayNameBox" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Unreal search root" FontWeight="SemiBold" />
                            <TextBox x:Name="UnrealSearchRootBox" />

                            <TextBlock Text="Project path" FontWeight="SemiBold" />
                            <TextBox x:Name="ProjectPathBox" />

                            <TextBlock Text="Shared output root" FontWeight="SemiBold" />
                            <TextBox x:Name="SharedOutputRootBox" />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Security">
                        <StackPanel>
                            <TextBlock Text="API token" FontWeight="SemiBold" />
                            <TextBox x:Name="ApiTokenBox" />
                            <TextBlock Text="Leave blank for local development. If the controller requires a token, use the same value here and on every worker." Foreground="#526078" TextWrapping="Wrap" />
                        </StackPanel>
                    </GroupBox>

                    <Border Background="#FFFFFF" BorderBrush="#D8DEE8" BorderThickness="1" CornerRadius="8" Padding="14">
                        <StackPanel>
                            <TextBlock Text="Status" FontWeight="SemiBold" />
                            <TextBlock x:Name="StatusText" Text="Ready." Foreground="#526078" TextWrapping="Wrap" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#D8DEE8" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,18,0,0">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="Save settings" Click="SaveSettings_Click" />
                    <Button Content="Start selected role" FontWeight="SemiBold" Click="StartRole_Click" />
                    <Button Content="Check controller" Click="CheckController_Click" />
                    <Button Content="Open dashboard" Click="OpenDashboard_Click" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button x:Name="InstallServiceButton" Content="Install worker service" Click="InstallWorkerService_Click" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
